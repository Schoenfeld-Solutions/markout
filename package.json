{
  "name": "markout",
  "version": "1.0.1",
  "description": "Outlook compose add-in for rendering Markdown into safe email HTML.",
  "author": "Schoenfeld Solutions (https://schoenfeld.solutions)",
  "repository": {
    "type": "git",
    "url": "https://github.com/Schoenfeld-Solutions/markout.git"
  },
  "bugs": {
    "url": "https://github.com/Schoenfeld-Solutions/markout/issues"
  },
  "homepage": "https://schoenfeld-solutions.github.io/markout/",
  "license": "MIT",
  "engines": {
    "node": ">=25 <27"
  },
  "config": {
    "app-to-debug": "outlook",
    "app-type-to-debug": "web",
    "dev-server-port": 3000
  },
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run build && npm run validate:manifest",
    "dev": "npm run dev-server",
    "dev-server": "webpack serve --mode development",
    "format": "prettier --cache --write \"AGENTS.md\" \"CONTRIBUTING.md\" \"README.md\" \".github/**/*.{yml,yaml}\" \"eslint.config.cjs\" \"jest.config.cjs\" \"package.json\" \"spec/**/*.ts\" \"src/**/*.{ts,html,css}\" \"tsconfig.json\" \"webpack.config.js\"",
    "format:check": "prettier --cache --check \"AGENTS.md\" \"CONTRIBUTING.md\" \"README.md\" \".github/**/*.{yml,yaml}\" \"eslint.config.cjs\" \"jest.config.cjs\" \"package.json\" \"spec/**/*.ts\" \"src/**/*.{ts,html,css}\" \"tsconfig.json\" \"webpack.config.js\"",
    "lint": "eslint .",
    "start": "npm run dev",
    "start:desktop": "office-addin-debugging start manifest-localhost.xml desktop",
    "start:web": "npm run dev",
    "stop": "office-addin-debugging stop manifest-localhost.xml",
    "test": "jest --runInBand",
    "test:host-smoke": "tsx spec/outlook-host-smoke.ts",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "validate:manifest": "office-toolbox validate -m manifest.xml && office-toolbox validate -m manifest.beta.xml",
    "validate:manifest:localhost": "office-toolbox validate -m manifest-localhost.xml",
    "watch": "webpack --mode development --watch"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "markdown-it-emoji": "^2.0.2",
    "markdown-it-footnote": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "@types/office-js": "^1.0.589",
    "@types/office-runtime": "^1.0.36",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "css-loader": "^7.1.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint": "^10.2.1",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^30.3.0",
    "jsdom": "^21.1.2",
    "office-addin-debugging": "^6.0.7",
    "office-addin-dev-certs": "^2.0.7",
    "office-toolbox": "^0.3.0",
    "playwright-core": "^1.56.0",
    "prettier": "^3.6.2",
    "source-map-loader": "^5.0.0",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.1",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "prettier": {
    "singleQuote": false,
    "trailingComma": "es5"
  }
}
